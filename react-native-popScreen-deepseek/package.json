{
  "name": "react-native-popscreen-deepseek",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "expo": "~57.0.2",
    "expo-dev-client": "~57.0.5",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:plugin": "cd plugin && npx tsc",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "setupFiles": [
      "./jest.setup.js"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "configFile": "./babel.config.jest.js"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|react-native-gesture-handler)/)"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/node_modules/react-native"
    }
  },
  "private": true,
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^30.0.0",
    "@types/react-test-renderer": "^19.1.0",
    "jest": "^29.7.0",
    "react-test-renderer": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
