.eslintrc*
.prettierrc*
tsconfig*.json
babel.config.*
jest.setup.js

# Editor / OS / AI config
.idea/
.vscode/
.claude/
.DS_Store
*.swp
*.swo

# Android build artifacts
android/.gradle/
android/app/build/
android/build/
android/captures/
android/local.properties
*.keystore
*.jks
