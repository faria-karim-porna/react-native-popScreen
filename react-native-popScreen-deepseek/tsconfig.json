{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx", "*.js", "*.tsx"],
  "exclude": ["node_modules", "android", "ios"]
}
